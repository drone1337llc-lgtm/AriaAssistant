# Aria autonomous backend — env file.
# Copy to `.env` in the project root for CrewAI to pick these up automatically.
# DO NOT commit a real `.env` with secrets.

# --- LM Studio endpoint (PC 2, AI box) --------------------------------------
LM_STUDIO_BASE_URL=http://192.168.68.88:1010/v1
LM_STUDIO_API_KEY=lm-studio

# --- Model selection --------------------------------------------------------
# Both default and strong currently use the user's fast 3B for predictability.
# Change STRONG_MODEL to `openai/minimax-m2.7` if you want the slow but deep
# reasoning model on Diagnostician + Knowledge Manager (60-90s per call).
AISISTANT_MODEL=openai/qwen2.5-3b-instruct
AISISTANT_STRONG_MODEL=openai/qwen2.5-3b-instruct

# --- Behavior flags ---------------------------------------------------------
# SAFE_MODE: when true, Fixer refuses taskkill/reconfigure/anything that
# touches Aria project files. Set to false ONLY if you've reviewed the
# action_executor whitelist and accept the risk.
AISISTANT_SAFE_MODE=true

# How often the runner ticks the Flow (seconds). 30s is a sensible default.
AISISTANT_TICK_SECONDS=30

# Where the live health log lives (parent directory).
ARIA_HEALTH_LOG_DIR=C:\Users\Tench\Documents\AI Learning