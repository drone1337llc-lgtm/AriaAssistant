# Aria Brain — env file.
# All paths are project-relative so the brain works on any host with this repo cloned.
#
# Setup:
#   If you don't have brain/.env, copy this file:
#     Copy-Item brain/.env.example brain/.env
#   Then edit the 3 paths at the bottom (ARIA_HEALTH_LOG_DIR, CHROMADB_FALLBACK_DIR, MOOD_STATE_PATH)
#   to point at the project root + a couple of subfolders.

# --- LLM (LM Studio - localhost since brain now runs on PC 2) ---------------
# PC 1 clients override ARIA_BRAIN_HOST via the stack script env hashtable,
# so they reach the brain at 192.168.68.88:8770.
LM_STUDIO_BASE_URL=http://127.0.0.1:1010/v1
LM_STUDIO_API_KEY=lm-studio

# Four role-based models:
#   chat    — Aria's voice
#   parser  — structured-output, JSON-friendly, fast
#   coder   — heavy reasoning, code, visual analysis
#   embed   — vector embeddings for ChromaDB
#   vision  — image / video / screenshot understanding
LM_STUDIO_CHAT_MODEL=humanish-roleplay-llama-3.1-8b-i1
LM_STUDIO_PARSER_MODEL=qwen2.5-coder-1.5b-instruct
LM_STUDIO_CODER_MODEL=nvidia_nvidia-nemotron-nano-9b-v2
LM_STUDIO_VISION_MODEL=qwen/qwen2.5-vl-7b
LM_STUDIO_EMBED_MODEL=text-embedding-qwen3-embedding-0.6b

# --- TTS (localhost since tts_server also runs on PC 2) ---------------------
# PC 1's chat_window overrides TTS_URL to http://192.168.68.88:5003/tts via env.
TTS_URL=http://127.0.0.1:5003/tts
TTS_VOICE=aria_default

# --- ChromaDB (localhost since brain + chromadb are both on PC 2) -----------
CHROMADB_URL=http://127.0.0.1:8000
CHROMADB_FALLBACK_DIR=C:\Users\Tench\Documents\AriaAssistantAppIKdiffusion\brain\chroma_local

# --- Brain service ----------------------------------------------------------
# 0.0.0.0 = bind all interfaces so PC 1 (tray, chat_window) can reach PC 2:8770.
# The stack script overrides ARIA_BRAIN_HOST=192.168.68.88 for PC 1 clients so
# their _brain_url() resolves to http://192.168.68.88:8770 (not 0.0.0.0).
ARIA_BRAIN_HOST=0.0.0.0
ARIA_BRAIN_PORT=8770

# --- Mood -------------------------------------------------------------------
MOOD_SCALE_MIN=1
MOOD_SCALE_MAX=5
MOOD_INITIAL=3
MOOD_DECAY_PER_HOUR=-0.083   # 0.5 per 6h
MOOD_DECAY_AFTER_HOURS=0.5   # start decaying after 30 min of silence
MOOD_BOOST_POSITIVE=1.0
MOOD_BOOST_QUESTION=0.5
MOOD_BOOST_NEGATIVE=-0.5

# --- Reflection -------------------------------------------------------------
REFLECTION_CADENCE_MINUTES=120
REFLECTION_ENABLED=true

# --- Personality ------------------------------------------------------------
PERSONA_NAME=Aria

# Force a language hint for the LLM. Set REPLY_LANGUAGE=none to disable.
REPLY_LANGUAGE=english

# --- Paths ------------------------------------------------------------------
# Aria's unified health log lives in the project root logs/ folder (shared with
# watchdog + motion server). If you don't set ARIA_HEALTH_LOG_DIR, the default
# is the project root, which means aria_health.log lands at the project root.
ARIA_HEALTH_LOG_DIR=C:\Users\Tench\Documents\AriaAssistantAppIKdiffusion\logs
ARIA_HEALTH_LOG=aria_health.log

# mood.json is Aria's current mood. The brain writes here every time mood changes.
MOOD_STATE_PATH=C:\Users\Tench\Documents\AriaAssistantAppIKdiffusion\brain\mood.json
